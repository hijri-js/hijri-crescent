{
  "name": "hijri-crescent",
  "version": "2.0.0",
  "description": "Get the officially moon-sighted Hijri date by Arab country, sourced from official government and Islamic authority websites",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "scrape": "tsx scripts/scrape.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc --noEmit --project tsconfig.scripts.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hijri-js/hijri-crescent.git"
  },
  "keywords": [
    "hijri",
    "islamic-calendar",
    "crescent",
    "moon-sighting",
    "arabic",
    "date",
    "typescript",
    "nodejs"
  ],
  "author": "Khaled Taymour",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hijri-js/hijri-crescent/issues"
  },
  "homepage": "https://github.com/hijri-js/hijri-crescent#readme",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "playwright": "^1.45.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
